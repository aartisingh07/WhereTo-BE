# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/whereto

# Security
JWT_SECRET=whereto_super_secret_key_change_this_in_production

# Third Party APIs
# Geolocation API (Geoapify) for finding nearby spots
GEOAPIFY_API_KEY=your_geoapify_api_key_here

# Movie API (TMDB) for room games/activities
TMDB_API_KEY=your_tmdb_api_key_here

# Cloud Storage API (Cloudinary) for uploading memories photos
CLOUDINARY_NAME=your_cloudinary_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here
